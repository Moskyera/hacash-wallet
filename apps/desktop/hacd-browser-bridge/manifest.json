{
  "manifest_version": 3,
  "name": "Hacash Wallet. HACD Bridge",
  "version": "0.1.53",
  "description": "Connects hacd.it to your local Hacash Wallet desktop app (MoneyNex-compatible).",
  "permissions": [],
  "host_permissions": ["http://127.0.0.1:9477/*"],
  "content_scripts": [
    {
      "matches": ["https://hacd.it/*", "https://*.hacd.it/*"],
      "js": ["inject.js"],
      "run_at": "document_start",
      "world": "MAIN"
    }
  ]
}
