{
    "$schema":  "https://schema.tauri.app/config/2",
    "productName":  "Hacash Wallet",
    "version":  "0.1.48",
    "identifier":  "org.hacash.wallet",
    "build":  {
                  "beforeDevCommand":  "yarn dev",
                  "devUrl":  "http://127.0.0.1:1420",
                  "beforeBuildCommand":  "yarn build",
                  "frontendDist":  "../dist"
              },
    "app":  {
                "windows":  [
                                {
                                    "title":  "Hacash Wallet",
                                    "width":  1100,
                                    "height":  760,
                                    "minWidth":  900,
                                    "minHeight":  640,
                                    "resizable":  true
                                }
                            ],
                "security":  {
                                 "csp":  "default-src \u0027self\u0027; base-uri \u0027none\u0027; object-src \u0027none\u0027; frame-src \u0027none\u0027; frame-ancestors \u0027none\u0027; form-action \u0027none\u0027; img-src \u0027self\u0027 data: blob:; font-src \u0027self\u0027; style-src \u0027self\u0027 \u0027unsafe-inline\u0027; script-src \u0027self\u0027; connect-src \u0027self\u0027 ipc: http://ipc.localhost http://127.0.0.1:1420 ws://127.0.0.1:1420 https://api.coingecko.com"
                             }
            },
    "bundle":  {
                   "active":  true,
                   "targets":  "all",
                   "icon":  [
                                "icons/icon.png",
                                "icons/icon.ico",
                                "icons/icon.icns"
                            ]
               }
}
