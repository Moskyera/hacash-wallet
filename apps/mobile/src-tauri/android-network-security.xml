<?xml version="1.0" encoding="utf-8"?>
<!--
  Cleartext is required only for the official Hacash node API (HTTP, not HTTPS).
  Same APK is used on stock Android, Honor, and GrapheneOS — no separate Graphene build.
  GrapheneOS: enable Network for this app in App info if balances never load.
-->
<network-security-config>
    <base-config cleartextTrafficPermitted="false">
        <trust-anchors>
            <certificates src="system" />
            <certificates src="user" />
        </trust-anchors>
    </base-config>
    <domain-config cleartextTrafficPermitted="true">
        <domain includeSubdomains="false">nodeapi.hacash.org</domain>
        <domain includeSubdomains="false">nodeapi.org</domain>
    </domain-config>
    <!-- Local-only development endpoints. -->
    <domain-config cleartextTrafficPermitted="true">
        <domain includeSubdomains="false">localhost</domain>
        <domain includeSubdomains="false">127.0.0.1</domain>
        <domain includeSubdomains="false">10.0.2.2</domain>
    </domain-config>
</network-security-config>
